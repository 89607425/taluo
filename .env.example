# API server
PORT=8787

# Frontend -> API proxy target for local development
VITE_API_PROXY_TARGET=http://localhost:8787

# MySQL（二选一）
# 方案A：连接串（推荐，适合 Railway）
DATABASE_URL=mysql://root:your_password@127.0.0.1:3306/taluo
# 方案B：分项配置（若用了 DATABASE_URL 可不填）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=taluo

# Redis
REDIS_URL=redis://127.0.0.1:6379

# SiliconFlow (主模型)
SILICONFLOW_API_KEY=your_siliconflow_key
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# 可选 fallback（PRD 备用模型）
FALLBACK_OPENAI_API_KEY=
FALLBACK_OPENAI_MODEL=gpt-3.5-turbo
